{
  "schema_version": 1,
  "domain": "content_patcher",
  "format": "2.9.0",
  "patch_actions": [
    {
      "action": "Load",
      "label": "Load 加载素材",
      "description": "Replace a target asset with a file from the content pack.",
      "required_fields": [
        "Action",
        "Target",
        "FromFile"
      ],
      "optional_fields": [
        "When",
        "LogName",
        "Priority"
      ],
      "field_hints": {
        "Target": "Game asset name to replace.",
        "FromFile": "File path inside the content pack, usually under assets/."
      }
    },
    {
      "action": "EditData",
      "label": "EditData 编辑数据",
      "description": "Change data assets with Entries, Fields, MoveEntries, or TextOperations.",
      "required_fields": [
        "Action",
        "Target"
      ],
      "optional_fields": [
        "Entries",
        "Fields",
        "MoveEntries",
        "TextOperations",
        "When",
        "LogName",
        "Priority"
      ],
      "field_hints": {
        "Entries": "Add or replace entries by key.",
        "Fields": "Patch fields within existing entries.",
        "TextOperations": "Apply text edits for string data."
      }
    },
    {
      "action": "EditImage",
      "label": "EditImage 编辑图片",
      "description": "Patch an image asset from a source image file.",
      "required_fields": [
        "Action",
        "Target",
        "FromFile"
      ],
      "optional_fields": [
        "FromArea",
        "ToArea",
        "PatchMode",
        "When",
        "LogName",
        "Priority"
      ],
      "field_hints": {
        "PatchMode": "Overlay by default; Replace should be used when overwriting a full area."
      }
    },
    {
      "action": "EditMap",
      "label": "EditMap 编辑地图",
      "description": "Patch a map asset with a map file or map operations.",
      "required_fields": [
        "Action",
        "Target"
      ],
      "optional_fields": [
        "FromFile",
        "FromArea",
        "ToArea",
        "MapTiles",
        "When",
        "LogName",
        "Priority"
      ]
    },
    {
      "action": "Include",
      "label": "Include 引入补丁",
      "description": "Include patches from another content file.",
      "required_fields": [
        "Action",
        "FromFile"
      ],
      "optional_fields": [
        "When",
        "LogName"
      ]
    }
  ],
  "tokens": [
    {
      "name": "ModId",
      "kind": "global",
      "description": "The current content pack unique ID."
    },
    {
      "name": "Season",
      "kind": "global",
      "description": "Current season."
    },
    {
      "name": "Day",
      "kind": "global",
      "description": "Current day of month."
    },
    {
      "name": "DayOfWeek",
      "kind": "global",
      "description": "Current weekday."
    },
    {
      "name": "Weather",
      "kind": "global",
      "description": "Current weather."
    },
    {
      "name": "PlayerName",
      "kind": "global",
      "description": "Current player name."
    },
    {
      "name": "HasMod",
      "kind": "condition",
      "description": "Whether a mod with the given unique ID is installed."
    },
    {
      "name": "Relationship",
      "kind": "condition",
      "description": "Relationship conditions for an NPC."
    },
    {
      "name": "i18n",
      "kind": "translation",
      "description": "Translation token, usually {{i18n:key}} or with arguments."
    },
    {
      "name": "Target",
      "kind": "patch",
      "description": "Patch target token available in some patch contexts."
    },
    {
      "name": "FromFile",
      "kind": "patch",
      "description": "Patch source file token available in some patch contexts."
    }
  ],
