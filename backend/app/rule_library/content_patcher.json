  "translations": {
    "folder": "i18n",
    "default_file": "i18n/default.json",
    "locale_file_pattern": "i18n/<locale>.json",
    "token_pattern": "{{i18n:key}}",
    "notes": [
      "Use stable translation keys instead of hard-coded user-facing text where practical.",
      "Keep default.json complete; locale files can override individual keys.",
      "Translation tokens may be used in content.json fields where token strings are supported."
    ]
  },
  "text_operations": {
    "description": "Content Patcher TextOperations edit delimited or matched text inside data strings.",
    "common_fields": [
      "Operation",
      "Target",
      "Value",
      "Delimiter",
      "Search",
      "Replace",
      "Before",
      "After"
    ],
    "operations": [
      {
        "operation": "Append",
        "description": "Append text to an existing value."
      },
      {
        "operation": "Prepend",
        "description": "Prepend text to an existing value."
      },
      {
        "operation": "Replace",
        "description": "Replace matching text."
      },
      {
        "operation": "Remove",
        "description": "Remove matching text."
      },
      {
        "operation": "ReplaceDelimited",
        "description": "Replace a delimited field within a string."
      },
      {
        "operation": "RemoveDelimited",
        "description": "Remove a delimited field from a string."
      }
    ],
    "guidance": [
      "Use TextOperations for string formats where replacing the whole entry would conflict with other mods.",
      "Gift tastes and other slash-delimited legacy strings often benefit from delimiter-aware operations."
    ]
  },
  "trigger_actions": {
    "description": "Trigger actions can be defined in game data and invoked by supported game systems or trigger hooks.",
    "content_patcher_guidance": [
      "Prefer stable unique IDs for custom trigger actions.",
      "Use Content Patcher conditions to gate patches which add trigger actions.",
      "When adding trigger actions through EditData, target Data/TriggerActions."
    ]
  },
  "ai_guidance": [
    "Always output valid JSON only when asked for a JSON fragment.",
    "Use Content Patcher field names exactly as documented, including Action, Target, FromFile, When, Entries, Fields, and Include.",
    "Prefer common tokens and conditions from the rule library; if unsure, explain uncertainty briefly outside JSON only when the user asked for prose.",
    "For user-facing text, prefer i18n keys when the project already uses translations.",
    "For legacy slash-delimited data strings, consider TextOperations instead of replacing entire entries."
  ]
}
